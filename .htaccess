# Archivo por defecto
DirectoryIndex index.php

# Ocultar extensión .php solo en el front (NO admin)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Excluir admin completamente
    RewriteRule ^admin/ - [L]

    # Si la URL tiene .php (fuera de admin), redirigir sin extensión (302 temporal)
    RewriteCond %{THE_REQUEST} /([^.]+)\.php[\s?] [NC]
    RewriteRule (.+)\.php$ $1 [R=302,L]

    # Si el archivo .php existe, servir sin extensión
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+)$ $1.php [L]
</IfModule>

# Compresión GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Cache de archivos estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Seguridad
Options -Indexes
