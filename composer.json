{
    "name": "dif-sma/cms-php",
    "description": "DIF San Mateo Atenco CMS PHP Migration",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "dompdf/dompdf": "^2.0",
        "phpoffice/phpspreadsheet": "^1.29",
        "maennchen/zipstream-php": "^2.1",
        "psr/simple-cache": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "DifCms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DifCms\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --bootstrap tests/bootstrap.php tests/"
    }
}
